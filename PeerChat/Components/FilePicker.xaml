<UserControl x:Class="PeerChat.Components.FilePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PeerChat.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Button Style="{StaticResource IconButtonStyle}" Content="Image" Height="20" Width="40" Grid.Row="0">
            <Button.Template>
                <ControlTemplate>
                    <TextBlock Text="Image" VerticalAlignment="Center" HorizontalAlignment="Center"  Foreground="{DynamicResource PngColor}"/>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button Style="{StaticResource IconButtonStyle}" Content="Image" Height="20" Width="40" Grid.Row="1">
            <Button.Template>
                <ControlTemplate>
                    <TextBlock Text="Video" VerticalAlignment="Center" HorizontalAlignment="Center"  Foreground="{DynamicResource PngColor}"/>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
