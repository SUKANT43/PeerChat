<UserControl x:Class="PeerChat.Components.VideoMessageComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PeerChat.Components"
             xmlns:conv="clr-namespace:PeerChat.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400"
             x:Name="VideoControl">

    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Border CornerRadius="8" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="#2D2D2D" 
                    CornerRadius="8,8,0,0">
                <Grid>
                    <Image Source="{Binding Thumbnail, ElementName=VideoControl}"
                           Stretch="Uniform"
                           MaxHeight="200"/>
                </Grid>
            </Border>

            <ProgressBar Grid.Row="1" 
                         Height="10" 
                         Minimum="0" 
                         Maximum="100" 
                         Value="{Binding Progress,RelativeSource={RelativeSource AncestorType=UserControl}}"
                         Visibility="{Binding IsReceiving,Converter={StaticResource BoolToVisibility}}"
                         Margin="0,0,0,0"/>

            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,10,0,10"
                        Visibility="{Binding IsReceiving,Converter={StaticResource InverseBoolConverter}}">

                <Button Style="{StaticResource PrimaryButtonStyle}" 
                        FontSize="15">
                    <TextBlock Text="▶︎" Margin="8,8,8,8"/>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>