<UserControl x:Class="PeerChat.Components.VideoMessageComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:conv="clr-namespace:PeerChat.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="300"
             x:Name="VideoControl">

    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Border CornerRadius="12" 
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="1"
            Padding="0,0,0,8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="{DynamicResource SurfaceElevatedBrush}" 
                    CornerRadius="12,12,0,0">

                <Grid>
                    <Image Source="{Binding Thumbnail, ElementName=VideoControl}"
                           Stretch="Uniform"
                           MaxHeight="160"
                           MinHeight="100"
                           Margin="0">

                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReceiving, ElementName=VideoControl}" Value="True">
                                        <Setter Property="Opacity" Value="0.6"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSending, ElementName=VideoControl}" Value="True">
                                        <Setter Property="Opacity" Value="0.6"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <Button Command="{Binding PlayVideo, ElementName=VideoControl}"
                            CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Width="48"
                            Height="48"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#CC000000" 
                                        CornerRadius="24">
                                    <TextBlock Text="▶" 
                                               FontSize="22" 
                                               Foreground="White"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="2,0,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DD000000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="12,10,12,0">
                <ProgressBar Height="4" 
                             Minimum="0" 
                             Maximum="100" 
                             Value="{Binding Progress, ElementName=VideoControl}"
                             Visibility="{Binding IsReceiving, ElementName=VideoControl, Converter={StaticResource BoolToVisibility}}"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource BorderBrush}"/>

                <ProgressBar Height="4" 
                             Minimum="0" 
                             Maximum="100" 
                             Value="{Binding Progress, ElementName=VideoControl}"
                             Visibility="{Binding IsSending, ElementName=VideoControl, Converter={StaticResource BoolToVisibility}}"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource BorderBrush}"/>

                <TextBlock Text="{Binding Progress, ElementName=VideoControl, StringFormat={}{0:0}%}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           HorizontalAlignment="Right"
                           Margin="0,12,0,0"
                           Visibility="{Binding IsReceiving, ElementName=VideoControl, Converter={StaticResource BoolToVisibility}}"/>

                <TextBlock Text="{Binding Progress, ElementName=VideoControl, StringFormat={}{0:0}%}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           HorizontalAlignment="Right"
                           Margin="0,12,0,0"
                           Visibility="{Binding IsSending, ElementName=VideoControl, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="{Binding FileName, ElementName=VideoControl}"
                       FontSize="11"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="12,8,12,4"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="260">

                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FileName, ElementName=VideoControl}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FileName, ElementName=VideoControl}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>