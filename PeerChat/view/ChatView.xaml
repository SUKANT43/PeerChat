<UserControl x:Class="PeerChat.View.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:PeerChat.Converters"
             xmlns:comp="clr-namespace:PeerChat.Components"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <conv:MessageAlignmentConverter x:Key="AlignConverter"/>
        <conv:MessageColorConverter x:Key="ColorConverter"/>
        <conv:MessageTextColorConverter x:Key="TextColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <comp:TopBar Grid.Row="0"
                     PeerName="{Binding PeerName}" 
                     ToggleThemeCommand="{Binding ToggleThemeCommand}" />

        <Border Grid.Row="1"
                Margin="10,10,10,5"
                Padding="8"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="16">

            <ScrollViewer x:Name="MessageScrollViewer"
                          VerticalScrollBarVisibility="Auto">
                

                <ItemsControl ItemsSource="{Binding MessageList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,4">
                                <Border Padding="10,8"
                                        MaxWidth="380"
                                        CornerRadius="14"
                                        HorizontalAlignment="{Binding Direction, Converter={StaticResource AlignConverter}}"
                                        Background="{Binding Direction, Converter={StaticResource ColorConverter}}">

                                    <StackPanel>
                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,0,0,5">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding FileName}"/>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Image">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Text="{Binding Content}"
                                                   FontWeight="Normal"
                                                   TextWrapping="Wrap"
                                                   FontSize="14">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource ChatSentTextBrush}"/>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Direction}" Value="Received">
                                                            <Setter Property="Foreground" Value="{DynamicResource ChatReceivedTextBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Text">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Image MaxWidth="320"
                                               MouseLeftButtonUp="ImageClick"
                                               Stretch="Uniform"
                                               Margin="0,5,0,0"
                                               Cursor="Hand"
                                               Source="{Binding ImageData}">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Image">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="2"
                Padding="10"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                CornerRadius="16"
                BorderThickness="1,1,1,0">

            <StackPanel>
                <Border Background="{DynamicResource BackgroundBrush}"
                        Margin="5,5,5,10"
                        Padding="10"
                        CornerRadius="12"
                        Visibility="{Binding IsImagePreviewVisible, Converter={StaticResource BoolToVisibility}}">

                    <StackPanel>
                        <Image Source="{Binding PreviewImage}"
                               MaxHeight="150"
                               Stretch="Uniform"
                               Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Command="{Binding CancelImageCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="80"
                                    Height="30"
                                    Margin="0,0,10,0"/>
                            <Button Content="Send"
                                    Command="{Binding SendImageCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="80"
                                    Height="30"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource IconButtonStyle}"
                            Command="{Binding OpenImageFolderCommand}"
                            ToolTip="Send Image">
                        <TextBlock Text="📎" FontSize="20" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Button>

                  

                    <TextBox Grid.Column="1"
                             Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
                             Height="40"
                             Padding="12,10"
                             VerticalContentAlignment="Center"
                             Background="{DynamicResource BackgroundBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1"
                             Margin="5,0">

                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SendMessageCommand}"/>
                        </TextBox.InputBindings>

                        <TextBox.Template>
                            <ControlTemplate TargetType="TextBox">
                                <Border CornerRadius="20"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        Background="{TemplateBinding Background}">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Margin="10,0"/>

                                </Border>
                            </ControlTemplate>
                        </TextBox.Template>
                    </TextBox>

                    <Button Grid.Column="2"
                            Command="{Binding SendMessageCommand}"
                            Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}"
                            Style="{StaticResource SendButtonStyle}">
                        <TextBlock Text="➤" FontSize="20" Foreground="White"/>
                    </Button>
                </Grid>

                <TextBlock Text="{Binding TypingStatus}"
                           FontSize="11"
                           FontStyle="Italic"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="10,5,0,0"
                           Visibility="{Binding IsTypingVisible, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>