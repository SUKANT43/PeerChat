    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#3D3D3D"/>

    <SolidColorBrush x:Key="PngColor" Color="White"/>


    <BitmapImage x:Key="PaperPinIcon" UriSource="/Assets/Dark/paperClip.png"/>
    <BitmapImage x:Key="VideoPinIcon" UriSource="/Assets/Dark/videoClip.png"/>
    <SolidColorBrush x:Key="IconHoverColor" Color="#3A3A3A"/>


</ResourceDictionary>