<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BackgroundBrush" Color="#0A0A0A"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#333333"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="Black"/>
    <SolidColorBrush x:Key="TextInverseBrush" Color="#1E1E1E"/>

    <SolidColorBrush x:Key="AccentBrush" Color="#7C4DFF"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#9B6BFF"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#2A1B4D"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#5B3EFF"/>

    <SolidColorBrush x:Key="DangerBrush" Color="#FF4444"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#FF6666"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#00C853"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFC107"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#2196F3"/>

    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#2A2A2A"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#404040"/>
