    <SolidColorBrush x:Key="ChatReceivedTextBrush" Color="#1F2937"/>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#3D3D3D"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#252525"/>

    <SolidColorBrush x:Key="ScrollbarTrackBrush" Color="#1E1E1E"/>
