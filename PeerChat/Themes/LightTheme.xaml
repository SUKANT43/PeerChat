<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#212121"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="Black"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#005A9E"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#D32F2F"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
    <SolidColorBrush x:Key="TextFadeBrush" Color="Gray"/>


    <!-- Chat Message Colors -->
    <SolidColorBrush x:Key="ChatSentBrush" Color="#127a73"/>
    <SolidColorBrush x:Key="ChatReceivedBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="ChatSentTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ChatReceivedTextBrush" Color="#111827"/>
</ResourceDictionary>