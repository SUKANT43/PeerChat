<Application x:Class="PeerChat.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PeerChat.ViewModel"
             xmlns:view="clr-namespace:PeerChat.View"
             StartupUri="MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>

            <DataTemplate DataType="{x:Type vm:ConnectionViewModel}">
                <view:ConnectionView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ChatViewModel}">
                <view:ChatView/>
            </DataTemplate>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/LightTheme.xaml"/>
                <ResourceDictionary Source="Themes/ButtonStyle.xaml"/>
                <ResourceDictionary Source="Themes/TextBoxStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>
    </Application.Resources>
</Application>